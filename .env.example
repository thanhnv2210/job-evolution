ANTHROPIC_API_KEY=your-api-key-here

# Ollama fallback (used automatically when Anthropic credits are exhausted)
# Install Ollama: https://ollama.com  then: ollama pull llama3.2
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=mistral

# PostgreSQL — score history persistence
# Create DB first: createdb job_evolution
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/job_evolution

# Max concurrent LLM calls during score-all (default: 5)
# Lower this if you hit Anthropic rate limits; raise it for Ollama (no rate limits)
SCORER_CONCURRENCY=5
